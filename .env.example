# ─── Telegram Bot ──────────────────────────────────────────────────────────────
BOT_TOKEN=your-telegram-bot-token-from-botfather
WEBSITE_URL=https://sezgi.edu.uz
# FSM session storage: "redis" (recommended) | "memory" (dev only)
FSM_STORAGE=redis

# ─── App ───────────────────────────────────────────────────────────────
PROJECT_NAME=Sezgi
VERSION=1.0.0
API_V1_STR=/api/v1
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Database ──────────────────────────────────────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=sezgi_user
POSTGRES_PASSWORD=sezgi_password
POSTGRES_DB=sezgi_db
DATABASE_URL=postgresql+asyncpg://sezgi_user:sezgi_password@localhost:5432/sezgi_db

# ─── Redis ─────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ─── JWT ───────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ─── Email ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=noreply@sezgi.edu
EMAILS_FROM_NAME=Sezgi Platform

# ─── AI / LLM ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# ─── Celery ────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── HEMIS OAuth ───────────────────────────────────────────────────────────────
HEMIS_CLIENT_ID=your-hemis-client-id
HEMIS_CLIENT_SECRET=your-hemis-client-secret
HEMIS_REDIRECT_URI=http://localhost:8000/api/v1/auth/hemis/callback
# Set to true to use mock data without real HEMIS credentials (demo mode)
USE_HEMIS_MOCK=false

# ─── RAG / ChromaDB ────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chromadb

# ─── Ollama (local LLM) ────────────────────────────────────────────────────────
# Make sure Ollama is running: ollama serve
# Pull the model first:        ollama pull mistral
OLLAMA_MODEL=mistral
